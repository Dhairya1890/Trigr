# -- Supabase -------------------------------------------------
# Replace with your project URL and service role key from supabase.com
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_service_role_key_here

# -- OpenWeatherMap -------------------------------------------
# Free tier key from openweathermap.org - used for rain/wind triggers
OPENWEATHER_API_KEY=your_openweathermap_key_here

# -- OpenAQ ---------------------------------------------------
# Free key from openaq.org - used for AQI triggers
OPENAQ_API_KEY=your_openaq_key_here

# -- NewsAPI --------------------------------------------------
# Free key from newsapi.org - used for curfew/strike detection
NEWSAPI_KEY=your_newsapi_key_here

# -- Razorpay -------------------------------------------------
# Test mode keys from razorpay.com/dashboard - used for penny drop and payouts
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

